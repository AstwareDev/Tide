GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Free tier: create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
SESSION_SECRET=
CRON_SECRET=

# Supabase Postgres connection string (use the "Transaction pooler" / port 6543
# connection string from Project Settings > Database, so it works in serverless).
DATABASE_URL=

# Base URL used to build the OAuth redirect URI (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000
