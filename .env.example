GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
SESSION_SECRET=
CRON_SECRET=

# Auto-injected by the Vercel KV / Upstash Redis integration in production;
# for local dev, create a KV store in the Vercel dashboard and pull the env vars.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Base URL used to build the OAuth redirect URI (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000
